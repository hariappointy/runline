{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "moduleDetection": "force",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "runline": ["../runline/dist"]
    }
  },
  "include": ["*/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
